{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://*.supabase.co https://*.n8n.cloud https://musigod-n8n.onrender.com https://cdn.jsdelivr.net https://api.stripe.com https://musigod.com https://api.discogs.com https://www.googleapis.com https://accounts.spotify.com https://api.spotify.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com;"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/dead",
            "destination": "/dead.html"
        },
        {
            "source": "/admin",
            "destination": "/admin.html"
        },
        {
            "source": "/portal",
            "destination": "/portal.html"
        },
        {
            "source": "/earnings",
            "destination": "/earnings.html"
        },
        {
            "source": "/registration/:path*",
            "destination": "/registration-detail.html"
        },
        {
            "source": "/success",
            "destination": "/success.html"
        },
        {
            "source": "/rights-audit",
            "destination": "/rights-audit.html"
        },
        {
            "source": "/affiliates",
            "destination": "/affiliate-dashboard.html"
        },
        {
            "source": "/audit-status",
            "destination": "/audit-status.html"
        },
        {
            "source": "/catalog-intake",
            "destination": "/catalog-intake.html"
        },
        {
            "source": "/audit-admin",
            "destination": "/audit-admin.html"
        },
        {
            "source": "/catalog-enrichment",
            "destination": "/catalog-enrichment.html"
        },
        {
            "source": "/catalog-splits",
            "destination": "/catalog-splits.html"
        },
        {
            "source": "/recovery-tracker",
            "destination": "/recovery-tracker.html"
        }
    ],
    "crons": [
        {
            "path": "/api/send-audit-drip",
            "schedule": "0 14 * * *"
        }
    ],
    "functions": {
        "api/run-enrichment-job.js": {
            "maxDuration": 300
        },
        "api/enrich-artist.js": {
            "maxDuration": 300
        },
        "api/save-writer-override.js": {
            "maxDuration": 10
        },
        "api/save-writer-splits.js": {
            "maxDuration": 10
        },
        "api/get-writer-splits.js": {
            "maxDuration": 10
        },
        "api/download-registration-csv.js": {
            "maxDuration": 30
        },
        "api/get-admin-queue.js": {
            "maxDuration": 10
        },
        "api/update-admin-queue-task.js": {
            "maxDuration": 10
        },
        "api/get-recovery-cases.js": {
            "maxDuration": 10
        }
    }
}